# ??????????????????????????????????????????????????????????
# EpiasPriceNotifier ? Production Environment Variables
# ??????????????????????????????????????????????????????????
# Bu dosya repo'da .env.example olarak kal?r. Ger?ek
# de?erler i?in kopyala -> .env yap -> kendi secret'lar?n? koy.
#
# ASP.NET Core configuration binding rules:
#   - `:` yerine `__` (Windows/Linux uyumlu)
#   - Boolean'lar "true"/"false" string olarak
#
# Container i?inde ConfigurationBuilder bu env vars'? otomatik
# read eder, appsettings.json'daki ayn? key'leri override eder.
# ??????????????????????????????????????????????????????????

# EP?A? ?effafl?k Platformu credentials
Epias__Username=your-epias-username
Epias__Password=your-epias-password

# Telegram Bot
Notifications__Telegram__BotToken=123456789:AABBccDDeeFFggHHii
Notifications__Telegram__ChatIds__User1=111111111
Notifications__Telegram__ChatIds__User2=222222222
Notifications__Telegram__ChatIds__User3=333333333
Notifications__Telegram__ChatIds__User4=444444444

# Gmail SMTP (App Password ? 2FA aktif olmal?)
Notifications__Email__From=your-gmail@gmail.com
Notifications__Email__AppPassword=abcd-efgh-ijkl-mnop
Notifications__Email__Addresses__User1=user1@example.com
Notifications__Email__Addresses__User2=user2@example.com
Notifications__Email__Addresses__User3=user3@example.com

# Ntfy topic (rastgele, tahmin edilemez bir string olmal?)
Notifications__Ntfy__Topics__User1=epias-yourname-random-string-xyz
