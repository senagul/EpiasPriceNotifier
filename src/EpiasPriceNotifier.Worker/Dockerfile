# ??????????????????????????????????????????????????????????????????????
# Stage 1: Build
# .NET 8 SDK image ? restore + build + publish
# ??????????????????????????????????????????????????????????????????????
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# ?nce sadece csproj dosyalar?n? kopyala ? restore layer'? cache'lensin diye.
# Source kodu sonra kopyalayaca??z; kaynak de?i?ti?inde restore tekrar ?al??mas?n.
COPY Directory.Packages.props ./
COPY EpiasPriceNotifier.slnx ./
COPY src/EpiasPriceNotifier.Domain/*.csproj ./src/EpiasPriceNotifier.Domain/
COPY src/EpiasPriceNotifier.Application/*.csproj ./src/EpiasPriceNotifier.Application/
COPY src/EpiasPriceNotifier.Infrastructure/*.csproj ./src/EpiasPriceNotifier.Infrastructure/
COPY src/EpiasPriceNotifier.Worker/*.csproj ./src/EpiasPriceNotifier.Worker/

RUN dotnet restore src/EpiasPriceNotifier.Worker/EpiasPriceNotifier.Worker.csproj

# ?imdi kaynak kodu kopyala
COPY src/ ./src/

# Publish ? Release config, output /app/publish
RUN dotnet publish src/EpiasPriceNotifier.Worker/EpiasPriceNotifier.Worker.csproj \
    -c Release \
    -o /app/publish \
    --no-restore

# ??????????????????????????????????????????????????????????????????????
# Stage 2: Runtime
# ASP.NET Core 8 runtime ? minimal, SDK yok
# ??????????????????????????????????????????????????????????????????????
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app

# tzdata: TimeZoneInfo.FindSystemTimeZoneById("Europe/Istanbul") i?in zorunlu
# Linux base image'da varsay?lan timezone db genelde var ama explicit install
# daha g?venli (alpine variant?nda yok).
RUN apt-get update && apt-get install -y --no-install-recommends tzdata && rm -rf /var/lib/apt/lists/*

# Container i?inde TZ env variable'? ? log'larda local time g?r?n?r
ENV TZ=Europe/Istanbul

# Publish ??kt?s?n? kopyala
COPY --from=build /app/publish ./

# SQLite dosyas? container i?inde /app/data dizininde ya?ayacak (volume mount edilecek)
RUN mkdir -p /app/data
ENV ConnectionStrings__Default="Data Source=/app/data/epias-price-notifier.db"

# Aspnet default HTTP port'u
EXPOSE 8080
ENV ASPNETCORE_URLS=http://+:8080

# Hosting environment Production
ENV ASPNETCORE_ENVIRONMENT=Production

ENTRYPOINT ["dotnet", "EpiasPriceNotifier.Worker.dll"]
