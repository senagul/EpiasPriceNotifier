{
    "ConnectionStrings": {
        "Default": "Data Source=epias-price-notifier.db"
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.EntityFrameworkCore": "Warning",
                "Quartz": "Warning",
                "System.Net.Http.HttpClient": "Warning"
            }
        }
    },
    "OpenTelemetry": {
        "Endpoint": "http://localhost:4317",
        "ServiceName": "EpiasPriceNotifier",
        "ServiceVersion": "1.0.0"
    },
    "AllowedHosts": "*",
    "Epias": {
        "BaseUrl": "https://seffaflik.epias.com.tr/electricity-service",
        "CasUrl": "https://giris.epias.com.tr/cas/v1/tickets",
        "TgtCacheMinutes": 100,
        "HttpTimeoutSeconds": 30
    },
    "Notifications": {
        "ThresholdTryPerKwh": 0.30,
        "Recipients": {
            "User1": [ "Telegram", "Email", "Ntfy" ],
            "User2": [ "Telegram", "Email" ],
            "User3": [ "Telegram", "Email" ],
            "User4": [ "Telegram" ]
        },
        "Telegram": {
        },
        "Email": {
            "SmtpHost": "smtp.gmail.com",
            "SmtpPort": 587
        },
        "Ntfy": {
            "BaseUrl": "https://ntfy.sh"
        }
    },
    "Scheduling": {
        "FetchAndNotifyCron": "0 0 15 * * ?",
        "TimeZone": "Turkey Standard Time"
    }
}